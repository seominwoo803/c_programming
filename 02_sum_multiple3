#include <stdio.h>

int main() {

	int n;

	scanf("%d", &n);

	int i;

	int add = 0;

	for (i = 1; i <= n; i++) {

		if (i % 3 == 0) {
			add += i;
		}

	}

	printf("%d", add);


	return 0;
}
